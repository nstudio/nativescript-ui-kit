  <!-- Examples of filters and transformations -->
  <GridLayout rows="auto,*" columns="auto,*" padding="20">

    <StackLayout row="0" scrollBarIndicatorVisible="false" margin="8 0 8 0">
      <WrapLayout padding="0 8">
        <Repeater items="{{ categories }}">
          <Repeater.itemTemplate>
            <Label text="{{ name }}" tap="onCategoryTap" margin="6" padding="12 18" borderRadius="99999" fontSize="16" fontWeight="600" color="#FFFFFF" backgroundColor="#6200EE" />
          </Repeater.itemTemplate>
        </Repeater>
      </WrapLayout>
    </StackLayout>

    <ScrollView row="1" scrollBarIndicatorVisible="false" margin="0 0 4 0">
      <WrapLayout padding="0 8">
        <Repeater items="{{ currentItems }}">
          <Repeater.itemTemplate>
            <Label text="{{ title }}" tap="onItemTap" margin="4" padding="8 14" borderRadius="99999" fontSize="14" fontWeight="500" color="#6200EE" backgroundColor="#F3E8FF" />
          </Repeater.itemTemplate>
        </Repeater>
      </WrapLayout>
    </ScrollView>

    <GridLayout rowSpan="2" col="1" rows="*,auto" horizontalAlignment="center" padding="8">
      <cl:ImageCloudinary options="{{ currentOptions }}" stretch="aspectFit" width="{{ imageSize }}" height="{{ imageSize }}" />
      <StackLayout row="1" padding="4 16 8 16" horizontalAlignment="left">
        <Label text="{{ currentTitle }}" fontWeight="bold" fontSize="18" color="#212121" />
        <Label text="{{ currentDescription }}" fontSize="13" color="#757575" textWrap="true" />
      </StackLayout>
    </GridLayout>

  </GridLayout>

</Page>

