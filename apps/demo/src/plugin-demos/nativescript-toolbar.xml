  xmlns="http://schemas.nativescript.org/tns.xsd"
  xmlns:tb="@nstudio/nativescript-toolbar"
  navigatingTo="navigatingTo"
  unloaded="{{ onDemoUnloaded }}"
  actionBarHidden="true"
  class="{{ pageClass }}">
  <GridLayout rows="auto,auto,*,auto,*,auto">
    <GridLayout row="0" rows="auto,auto" class="toolbar-demo-header">
      <Label row="0" text="API Explorer" color="#93c5fd" fontSize="12" />
      <Label row="1" text="iOS Toolbar" color="#f8fafc" fontSize="28" fontWeight="700" />
    </GridLayout>

    <StackLayout row="1" visibility="{{ topToolbarVisibility }}" class="mt-4">
      <!-- <GridLayout class="toolbar-demo-toolbar-surface"> -->
        <tb:NativescriptToolbar loaded="{{ onTopToolbarLoaded }}" height="48" />
      <!-- </GridLayout> -->
    </StackLayout>

